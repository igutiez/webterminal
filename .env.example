# =============================================================================
# WebTerminal — configuración (el instalador la escribe en /opt/webterminal/.env)
# Copia de referencia: cp .env.example .env y rellena.
# .env y backend/secret_key.txt están en .gitignore (NUNCA se versionan).
# =============================================================================

# ─── OBLIGATORIO ─────────────────────────────────────────────────────────────
# Clave de firma de los JWT del login web. Genérala con: openssl rand -hex 32
# Si falta (y no existe backend/secret_key.txt), el servicio no arranca.
WEBTERMINAL_SECRET_KEY=

# URL pública con la que se accede a la app. De aquí se deriva el origen del
# WebSocket para la CSP (https → wss, http → ws). Ejemplos:
#   https://terminal.ejemplo.com      (Caddy/nginx o Cloudflare Tunnel)
#   http://100.64.0.12:8765           (Tailscale / solo red local)
WEBTERMINAL_URL=

# ─── SSH de destino (a qué máquina/puerto se conecta la terminal) ────────────
WEBTERMINAL_SSH_HOST=127.0.0.1
WEBTERMINAL_SSH_PORT=22

# ─── Rutas (por defecto, todo bajo /opt/webterminal) ─────────────────────────
WEBTERMINAL_FRONTEND=/opt/webterminal/frontend
WEBTERMINAL_DB=/opt/webterminal/webterminal.db
WEBTERMINAL_UPLOAD_DIR=/opt/webterminal/uploads

# ─── Límites ─────────────────────────────────────────────────────────────────
# Nº máximo de sesiones simultáneas (5) · subida máxima en MB (100)
WEBTERMINAL_MAX_CONNECTIONS=5
WEBTERMINAL_MAX_UPLOAD_MB=100
# Anti fuerza bruta del SSH: intentos fallidos (5) y bloqueo en segundos (300)
WEBTERMINAL_MAX_SSH_FAILS=5
WEBTERMINAL_LOCK_SECONDS=300

# ─── tmux (sesiones persistentes) ────────────────────────────────────────────
# 1 = la sesión sobrevive a cortes de red y cierres del navegador (recomendado).
WEBTERMINAL_TMUX=1
# La sesión real es "<prefijo>-<email saneado>", una por usuario web.
WEBTERMINAL_TMUX_SESSION=web

# ─── Email de recuperación de contraseña (opcional) ──────────────────────────
# Sin SMTP todo funciona igual, salvo el correo de "olvidé mi contraseña".
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM_EMAIL=noreply@localhost
SMTP_FROM_NAME=WebTerminal
