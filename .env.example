# WebTerminal — variables de entorno.
# Copia este archivo a .env y rellénalo:   cp .env.example .env
# .env y backend/secret_key.txt están en .gitignore (NUNCA se versionan).

# ─── OBLIGATORIO ────────────────────────────────────────────────────────────
# Clave de firma de los JWT. Genérala con:  openssl rand -hex 32
# Si la dejas vacía aquí, la app la lee de backend/secret_key.txt.
# Si faltan ambas, el servicio no arranca.
WEBTERMINAL_SECRET_KEY=

# Contraseña de los certificados cliente .p12 (solo la usa setup.sh al crearlos).
WEBTERMINAL_P12_PASS=

# ─── OPCIONAL (entre paréntesis, el valor por defecto) ──────────────────────
# URL pública del servicio (https://terminal.vistawib.com)
WEBTERMINAL_URL=

# Carpeta donde se guardan los archivos subidos (/home/ubuntu/imagenes_temp).
# Se vacía cada noche a las 00:00 vía cron (/etc/cron.d/webterminal-temp-cleanup).
WEBTERMINAL_UPLOAD_DIR=

# Tamaño máximo de subida en MB (100 por defecto)
WEBTERMINAL_MAX_UPLOAD_MB=

# SMTP para los correos de recuperación de contraseña (Postfix local por defecto)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM_EMAIL=noreply@vistawib.com
SMTP_FROM_NAME=WebTerminal
